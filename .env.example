# vLLM Inference
INFERENCE_MODEL=your-model-name
VLLM_URL=https://your-vllm-endpoint/v1
VLLM_API_TOKEN=your-api-token
VLLM_TLS_VERIFY=false
VLLM_MAX_TOKENS=8192

# vLLM Embedding
EMBEDDING_MODEL=your-embedding-model
EMBEDDING_PROVIDER_MODEL_ID=your-embedding-model
EMBEDDING_DIMENSION=768
VLLM_EMBEDDING_URL=https://your-embedding-endpoint
VLLM_EMBEDDING_API_TOKEN=your-embedding-token
VLLM_EMBEDDING_TLS_VERIFY=false

# Namespace (default: llama-stack)
NAMESPACE=llama-stack
